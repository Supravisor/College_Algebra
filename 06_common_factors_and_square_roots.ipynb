   "source": [
    "# The modulus operator (%) finds the remainder"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "8b0bbc7b-8cf6-41ea-8b88-2ba37fdcabf5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2\n",
      "1\n"
     ]
    }
   ],
   "source": [
    "print(5%3)\n",
    "print(31%10)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "56972cb3-e314-49f7-960a-8d08b823108e",
   "metadata": {},
   "source": [
    "# Use the modulus in a loop to find factors"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "933b82dc-f3ad-47e1-aa8c-5223a825f3d0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1\n",
      "2\n",
      "3\n",
      "4\n",
      "6\n",
      "12\n"
     ]
    }
   ],
   "source": [
    "number = 12\n",
    "\n",
    "# Find all factors\n",
    "for test_factor in range(1,number+1):\n",
    "    if number%test_factor==0:\n",
    "        print(test_factor)"
   ]
  },
